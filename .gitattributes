# Normalize line endings across Windows and Linux/WSL.
# Text files are stored as LF in the repo and checked out as LF.
# * text=auto lets git auto-detect; the explicit rules below make it robust.
* text=auto eol=lf

# Source / config / docs — always LF
*.ts     text eol=lf
*.tsx    text eol=lf
*.js     text eol=lf
*.jsx    text eol=lf
*.mjs    text eol=lf
*.cjs    text eol=lf
*.json   text eol=lf
*.css    text eol=lf
*.html   text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.sh     text eol=lf
*.sql    text eol=lf
*.toml   text eol=lf
*.env*   text eol=lf

# Windows-only scripts keep CRLF so they execute correctly on Windows
*.bat    text eol=crlf
*.cmd    text eol=crlf
*.ps1    text eol=crlf

# Binary assets — never normalize
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.svg    binary
*.pdf    binary
*.woff   binary
*.woff2  binary
*.ttf    binary
